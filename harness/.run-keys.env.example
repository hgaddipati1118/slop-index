# Copy to harness/.run-keys.env and fill in. `set -a; source harness/.run-keys.env; set +a`.
# Only the providers for the models you actually run are needed (see providers.py MODELS).
# Keys are read from the environment at call time and are NEVER committed.
export OPENAI_API_KEY=
export ANTHROPIC_API_KEY=
export GEMINI_API_KEY=
export XAI_API_KEY=
export MISTRAL_API_KEY=
export FIREWORKS_API_KEY=          # DeepSeek / Kimi / GLM via Fireworks
export OPENROUTER_API_KEY=         # Qwen / MiniMax / Mistral flank
export META_SPARK_API_KEY=         # Meta Spark custom endpoint
# Optional detector cross-check:
export PANGRAM_API_KEY=
