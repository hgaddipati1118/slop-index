{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/benchmark.html", "destination": "/leaderboard", "permanent": true },
    { "source": "/benchmark", "destination": "/leaderboard", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "headers": [
    { "source": "/(pairs|prompts|logos|bench).json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=604800" }] },
    { "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ]
}
