# Copy to site/.admin-secrets (gitignored) and set the same values as Vercel env vars.
# All server-side; the browser never sees them.
export TOKEN_SECRET=          # HMAC secret for signed session + pair tokens
export IP_SALT=               # salt for the one-way IP hash in the vote log
export ADMIN_TOKEN=           # protects /api/admin (reset / wipe / recompute)
export TURNSTILE_SITE_KEY=    # Cloudflare Turnstile (public)
export TURNSTILE_SECRET=      # Cloudflare Turnstile (secret)
# Vote store (Upstash Redis REST, or Vercel KV aliases):
export UPSTASH_REDIS_REST_URL=
export UPSTASH_REDIS_REST_TOKEN=
